# Phase 1 (local stdio MCP server) — copy to .env or set in your
# Claude Desktop config's "env" block. .env is gitignored.

# GitHub fine-grained PAT scoped to mkurtay/kurtays-calendar
# Permissions: Contents (Read and write), Metadata (Read)
# Generate: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repo coordinates (defaults work for the canonical setup)
GITHUB_OWNER=mkurtay
GITHUB_REPO=kurtays-calendar
GITHUB_BRANCH=main

# Phase 2+ (HTTP MCP server, NOT used in Phase 1):
# MCP_BEARER_TOKEN=<random-string-shared-with-bot-Lambda>
#
# Phase 3+ (Telegram bot, NOT used in Phase 1):
# ANTHROPIC_API_KEY=sk-ant-...
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
