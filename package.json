{
  "name": "calendar-bot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "MCP server that exposes calendar mutation tools backed by mkurtay/kurtays-calendar. Phase 1 ships stdio transport for Claude Desktop; later phases add HTTP transport and a Telegram bot frontend.",
